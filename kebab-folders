#!/usr/bin/env bash

TARGET_DIR=""
DRY_RUN=true

print_usage() {
    echo "Usage: kebab-folders [OPTIONS] <directory>"
    echo ""
    echo "Convert folder names to kebab-case"
    echo ""
    echo "Options:"
    echo "  --execute     Actually rename folders (default is dry-run)"
    echo "  --dry-run     Preview changes (default)"
    echo "  --help, -h    Show this help message"
    echo ""
    echo "Examples:"
    echo "  kebab-folders ~/Music              Preview changes"
    echo "  kebab-folders --execute ~/Music    Execute changes"
}

while [[ $# -gt 0 ]]; do
    case $1 in
        --execute)
            DRY_RUN=false
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --help|-h)
            print_usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            echo "Unknown option: $1"
            echo "Use --help for usage"
            exit 1
            ;;
        *)
            TARGET_DIR="$1"
            shift
            ;;
    esac
done

if [[ -z "$TARGET_DIR" ]]; then
    echo "Error: No directory specified"
    echo "Use --help for usage"
    exit 1
fi

if [[ ! -d "$TARGET_DIR" ]]; then
    echo "Error: '$TARGET_DIR' is not a directory"
    exit 1
fi

TARGET_DIR=$(cd "$TARGET_DIR" && pwd)

lower_ascii() {
    LC_ALL=C tr '[:upper:]' '[:lower:]'
}

to_kebab_case() {
    local input="$1"
    local result
    result=$(printf '%s' "$input" | iconv -f UTF-8 -t ASCII//TRANSLIT 2>/dev/null || printf '%s' "$input")
    result=$(printf '%s' "$result" | \
        tr '\n\r\t' '   ' | \
        lower_ascii | \
        sed "s/[\"'\\\`]//g" | \
        sed 's/[^a-z0-9]/-/g' | \
        sed 's/-\+/-/g' | \
        sed 's/^-//' | sed 's/-$//')
    [[ -z "$result" ]] && result="unnamed"
    echo "$result"
}

same_fs_entry() {
    local a="$1"
    local b="$2"

    local sa=""
    local sb=""
    if sa=$(stat -c '%d:%i' "$a" 2>/dev/null); then
        :
    elif sa=$(stat -f '%d:%i' "$a" 2>/dev/null); then
        :
    else
        return 1
    fi

    if sb=$(stat -c '%d:%i' "$b" 2>/dev/null); then
        :
    elif sb=$(stat -f '%d:%i' "$b" 2>/dev/null); then
        :
    else
        return 1
    fi

    [[ "$sa" == "$sb" ]]
}

lower_string() {
    local s="$1"
    printf '%s' "$s" | lower_ascii
}

safe_rename_dir() {
    local src="$1"
    local dst="$2"

    if mv "$src" "$dst" 2>/dev/null; then
        return 0
    fi

    local parent="${dst%/*}"
    [[ -z "$parent" ]] && parent="/"
    local tmp=""
    local i=0
    while [[ $i -lt 20 ]]; do
        tmp="${parent}/.kebab-folders-tmp-$$-$RANDOM"
        [[ -e "$tmp" ]] || break
        ((i++))
    done
    [[ -n "$tmp" && ! -e "$tmp" ]] || return 1

    if ! mv "$src" "$tmp" 2>/dev/null; then
        return 1
    fi

    if mv "$tmp" "$dst" 2>/dev/null; then
        return 0
    fi

    mv "$tmp" "$src" 2>/dev/null || true
    return 1
}

echo "=== kebab-folders ==="
echo "Target: $TARGET_DIR"
echo "Mode: $(if $DRY_RUN; then echo 'DRY RUN'; else echo 'EXECUTE'; fi)"
echo ""

changes=0
errors=0

while IFS= read -r -d '' dir; do
    [[ "$dir" == "$TARGET_DIR" ]] && continue

    parent="${dir%/*}"
    [[ -z "$parent" ]] && parent="/"
    basename="${dir##*/}"
    newname=$(to_kebab_case "$basename")

    [[ "$basename" == "$newname" ]] && continue

    newpath="$parent/$newname"

    if [[ -e "$newpath" ]] && ! same_fs_entry "$dir" "$newpath"; then
        if [[ "$(lower_string "$basename")" != "$newname" ]]; then
            printf 'CONFLICT: %q -> %q (target exists)\n' "$dir" "$newpath"
            ((errors++))
            continue
        fi
    fi

    ((changes++))

    if $DRY_RUN; then
        printf '%q -> %q\n' "$dir" "$newpath"
    else
        if safe_rename_dir "$dir" "$newpath"; then
            printf 'RENAMED: %q -> %q\n' "$dir" "$newpath"
        else
            printf 'ERROR: %q\n' "$dir"
            ((errors++))
        fi
    fi
done < <(find "$TARGET_DIR" -depth -type d -print0)

echo ""
echo "Changes: $changes | Errors: $errors"

if $DRY_RUN && [[ $changes -gt 0 ]]; then
    echo ""
    echo "Run with --execute to apply changes"
fi
